# Copy to .env.local and fill in. The app runs on mock data with NONE of these set.

# --- Supabase (backend / DB / auth) ---
# From your Supabase project settings → API. Use the EU region for GDPR (docs/02).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY, bypasses RLS. Used by the Stripe webhook to
# mark bookings paid. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL, used for Stripe Checkout success/cancel redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Maps (Mapbox) ---
# Public token for map rendering. Without it, a schematic map is shown.
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Web Push (PWA notifications, docs/04) ---
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Payments (Stripe Connect, docs/02) ---
# Use TEST-mode keys (sk_test_… / pk_test_…) to accept test cards, no real money.
# Without these, booking uses a simulated payment (booking is confirmed instantly).
# Hosts must be onboarded as connected accounts for the real destination charge.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Identity (BankID via Criipto / Signicat, docs/07) ---
BANKID_PROVIDER_CLIENT_ID=
BANKID_PROVIDER_CLIENT_SECRET=
